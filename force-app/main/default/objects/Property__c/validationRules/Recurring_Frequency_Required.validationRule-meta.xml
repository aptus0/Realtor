<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Recurring_Frequency_Required</fullName>
    <active>true</active>
    <description>Frequency must match the recurring flag.</description>
    <errorConditionFormula>OR(AND(Recurring__c, ISBLANK(TEXT(Frequency__c))), AND(NOT(Recurring__c), NOT(ISBLANK(TEXT(Frequency__c)))))</errorConditionFormula>
    <errorMessage>Select Frequency only when Recurring is checked.</errorMessage>
</ValidationRule>
